include README.md
include LICENSE*
include pyproject.toml
include setup.py

# Include C source files
recursive-include src/combinatorial_codes *.c *.h

# Include test files for regression testing
recursive-include tests *.py
include pytest.ini

# Include data files if any
recursive-include src/combinatorial_codes *.txt *.dat *.json

# Exclude build artifacts and cache
global-exclude *.pyc
global-exclude *.pyo
global-exclude *.pyd
global-exclude __pycache__
global-exclude .git*
global-exclude .DS_Store
global-exclude *.so
prune build
prune dist
prune *.egg-info
